{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.1",
      "excludeFiles": "{.next,*.cache,node_modules,public,app}/**"
    }
  },
  "installCommand": "composer install --no-dev --optimize-autoloader",
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "outputDirectory": "public"
}